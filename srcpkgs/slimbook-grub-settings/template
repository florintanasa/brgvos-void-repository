wrksrc="slimbook-grub-settings-main"

do_install() {
	vmkdir etc/default/grub.d
	
        # ADVANCED USERS: By default, BRGV-OS KEEPS the Slimbook fix
        # which DISABLES AMD IOMMU (amd_iommu=off).
        # If you need IOMMU for virtualization (PCI passthrough), 
        # uncomment the 'rm' line below to remove the fix during build.
        # rm -f slimbook-amd_iommu-fix.cfg


	# Install all hardware fix configurations
	vcopy "*.cfg" etc/default/grub.d
}
