# Template file for 'lemonade-server'
pkgname=lemonade-server
version=10.6.0
revision=1
_httplibver=0.45.0
build_style=cmake
configure_args="-G Ninja -D FETCHCONTENT_FULLY_DISCONNECTED=ON
 -D FETCHCONTENT_SOURCE_DIR_HTTPLIB=${XBPS_BUILDDIR}/${pkgname}-${version}/cpp-httplib-${_httplibver}"
hostmakedepends="pkg-config cmake ninja git nodejs"
makedepends="libwebsockets-devel openssl-devel libdrm-devel libzstd-devel json-c++ cli11 libcurl-devel"
depends="zstd unzip libwebsockets"
system_accounts="lemonade"
short_desc="Local LLM Serving with GPU and NPU acceleration (Server)"
maintainer="Florin Tanasă <florin.tanasa@gmail.com>"
license="Apache-2.0"
homepage="https://github.com/lemonade-sdk/lemonade"

distfiles="${homepage}/archive/refs/tags/v${version}.tar.gz>lemonade-${version}.tar.gz
 https://github.com/yhirose/cpp-httplib/archive/refs/tags/v${_httplibver}.tar.gz>cpp-httplib-${_httplibver}.tar.gz"

checksum="552d4585044e482b017a2cd6522731cef42d5984673db2daf43056065643060e
 03121ca28d210ac8014021c2f2deda4a181f215b1638c493c40a4c7e6056495f"

build_wrksrc="lemonade-${version}"

post_install() {
	vmkdir var/lib/lemonade 750 lemonade lemonade
	touch ${DESTDIR}/var/lib/lemonade/.keep_lemonade-server_0

	vmkdir etc/lemonade 750 lemonade lemonade

	rm -rf ${DESTDIR}/usr/lib/systemd

	vsv lemonade-server
}
