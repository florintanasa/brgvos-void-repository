do_install() {
	mkdir -p ${DESTDIR}/usr
	tar -x --zstd -f ${XBPS_SRCDISTDIR}/${pkgname}-${version}/ollama-linux-amd64-rocm.tar.zst -C ${DESTDIR}/usr
}
