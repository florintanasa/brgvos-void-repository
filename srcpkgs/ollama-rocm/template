# Template file for 'ollama-rocm'
pkgname=ollama-rocm
version=7.2.70201
revision=1
archs="x86_64"
hostmakedepends="zstd tar"
depends="ollama>=0.24.0"
nostrip=yes
allow_unknown_shlibs=yes
