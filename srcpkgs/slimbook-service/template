# Template file for 'slimbook-service'
pkgname=slimbook-service
version=1.0.10
revision=1
no_target=yes
depends="libayatana-appindicator libnotify libslimbook power-profiles-daemon
 python3-evdev python3-feedparser python3-gobject python3-pyudev python3-pyzmq
 python3-requests python3-slimbook python3-dateutil bubblewrap"
short_desc="Slimbook background service for notifications and events"
maintainer="Florin Tanasă <florin.tanasa@gmail.com>"
license="GPL-3.0-or-later"
homepage="https://github.com/Slimbook-Team/slimbook_service"
distfiles="${homepage}/archive/refs/tags/${version}.tar.gz>slimbook_service-${version}.tar.gz"
checksum=a6c43a105725f00ed9045d4a633afeae8cbcbe8cedc14176d8888a41e718e258

wrksrc="slimbook_service-${version}"

do_install() {
	cd slimbook

	# 1. Binary file
	vbin bin/slimbookindicator

	# 2. Python and Desktop resources
	vmkdir usr/share/slimbook
	# Copies all from slimbook
	vcopy "usr/share/slimbook/*" usr/share/slimbook

	# 3. Install icons
	vmkdir usr/share/icons
	vcopy "usr/share/icons/*" usr/share/icons

	# 4. Desktop integration (Menu & Autostart)
	vinstall usr/share/slimbook/slimbook-indicator.desktop 644 usr/share/applications
	vmkdir etc/xdg/autostart
	vinstall usr/share/slimbook/slimbook-client-autostart.desktop 644 etc/xdg/autostart
}


post_install() {
	# 6. Runit Service
	vsv slimbook
}
